# Copy to .env for local dev (run.sh loads it). Never commit the real .env.
# These are read from the environment, never from config.yaml.

# Discord delivery (F7)
DISCORD_WEBHOOK_URL=

# Gmail delivery (F8) — GMAIL_APP_PASSWORD is a Gmail App Password (needs 2FA)
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
GMAIL_TO=
